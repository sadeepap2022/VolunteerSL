# ================================
# VolunteerSL Environment Variables
# Copy this to .env.local and fill in the values
# ================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/volunteersl?sslmode=require"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET="<your-auth-secret>"
AUTH_URL="http://localhost:3000"

# WSO2 Asgardeo OIDC
# Find these in your Asgardeo application settings
ASGARDEO_CLIENT_ID="<your-asgardeo-client-id>"
ASGARDEO_CLIENT_SECRET="<your-asgardeo-client-secret>"
# Replace <org-name> with your Asgardeo organization name
ASGARDEO_ISSUER="https://api.asgardeo.io/t/<org-name>/oauth2/token"

# Prisma Field Encryption (32-byte base64 key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PRISMA_FIELD_ENCRYPTION_KEY="<your-encryption-key>"

# PayHere Payment Gateway
# Get from https://www.payhere.lk/
PAYHERE_MERCHANT_ID="<your-merchant-id>"
PAYHERE_MERCHANT_SECRET="<your-merchant-secret>"
PAYHERE_SANDBOX="true"
# Set to "false" in production

# Vercel Blob (for receipt uploads)
# Get from Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN="<your-vercel-blob-token>"

# App URL (update for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin provisioning (seed script only — remove in production)
# Set to your Asgardeo sub (user ID) to make that user an admin
SEED_ADMIN_SUB=""
